# QA-AI Framework – Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Target Application ────────────────────────────────────────────────────
BASE_URL=https://reqres.in
API_BASE_URL=https://reqres.in/api

# ── Auth (if target requires it) ─────────────────────────────────────────
API_KEY=
AUTH_TOKEN=

# ── Test Behaviour ────────────────────────────────────────────────────────
TEST_ENV=development          # development | staging | production
LOG_LEVEL=info                # debug | info | warn | error
HEADLESS=true                 # false to watch browser during local runs

# ── Timeouts (ms) ─────────────────────────────────────────────────────────
NAVIGATION_TIMEOUT=15000
ACTION_TIMEOUT=10000
API_TIMEOUT=10000

# ── AI Features ───────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
# Without this key, AI features run in heuristic mock mode (still functional)
GROQ_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────
SLACK_WEBHOOK=
